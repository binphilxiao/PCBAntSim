<Window x:Class="AntennaSimulatorApp.Views.FarFieldResultWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:h="http://helix-toolkit.org/wpf"
        Title="Far-Field Results"
        Width="960"
        Height="680"
        MinWidth="700"
        MinHeight="500"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="True"
        PreviewKeyDown="Window_PreviewKeyDown">

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Key metrics bar -->
        <Border Grid.Row="0"
                Background="#F0F4F8"
                CornerRadius="4"
                Padding="12,8"
                Margin="0,0,0,10">
            <WrapPanel>
                <StackPanel Orientation="Horizontal"
                            Margin="0,0,24,0">
                    <TextBlock Text="Frequency: "
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                    <TextBlock x:Name="TxtFrequency"
                               Text="—"
                               FontSize="14"
                               FontWeight="Bold"
                               Foreground="#1565C0"
                               VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal"
                            Margin="0,0,24,0">
                    <TextBlock Text="Directivity: "
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                    <TextBlock x:Name="TxtDirectivity"
                               Text="—"
                               FontSize="14"
                               FontWeight="Bold"
                               Foreground="#C62828"
                               VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal"
                            Margin="0,0,24,0">
                    <TextBlock Text="Efficiency: "
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                    <TextBlock x:Name="TxtEfficiency"
                               Text="—"
                               FontSize="14"
                               FontWeight="Bold"
                               Foreground="#2E7D32"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </WrapPanel>
        </Border>

        <!-- Tabbed chart area -->
        <TabControl Grid.Row="1"
                    x:Name="ChartTabs"
                    SelectionChanged="ChartTabs_SelectionChanged">
            <TabItem Header="Rectangular Pattern">
                <Border BorderBrush="#CCC"
                        BorderThickness="1"
                        CornerRadius="3"
                        Background="White"
                        ClipToBounds="True">
                    <Canvas x:Name="RectCanvas"
                            Background="White"
                            SizeChanged="Canvas_SizeChanged"/>
                </Border>
            </TabItem>
            <TabItem Header="Polar E-Plane">
                <Border BorderBrush="#CCC"
                        BorderThickness="1"
                        CornerRadius="3"
                        Background="White"
                        ClipToBounds="True">
                    <Canvas x:Name="PolarECanvas"
                            Background="White"
                            SizeChanged="Canvas_SizeChanged"/>
                </Border>
            </TabItem>
            <TabItem Header="Polar H-Plane">
                <Border BorderBrush="#CCC"
                        BorderThickness="1"
                        CornerRadius="3"
                        Background="White"
                        ClipToBounds="True">
                    <Canvas x:Name="PolarHCanvas"
                            Background="White"
                            SizeChanged="Canvas_SizeChanged"/>
                </Border>
            </TabItem>
            <TabItem Header="3D Pattern">
                <Border BorderBrush="#CCC"
                        BorderThickness="1"
                        CornerRadius="3"
                        Background="White"
                        ClipToBounds="True">
                    <Grid>
                        <!-- View control toolbar -->
                        <Border VerticalAlignment="Top"
                                HorizontalAlignment="Left"
                                Background="#DD2B3A4A"
                                CornerRadius="4"
                                Margin="8"
                                Padding="4"
                                Panel.ZIndex="10">
                            <Border.Resources>
                                <Style TargetType="Button">
                                    <Setter Property="Foreground"
                                            Value="#EEEEEE"/>
                                    <Setter Property="Background"
                                            Value="#444444"/>
                                    <Setter Property="BorderBrush"
                                            Value="#666666"/>
                                    <Setter Property="BorderThickness"
                                            Value="1"/>
                                    <Setter Property="Margin"
                                            Value="2,2"/>
                                    <Setter Property="Padding"
                                            Value="7,3"/>
                                    <Setter Property="FontSize"
                                            Value="11"/>
                                    <Setter Property="Cursor"
                                            Value="Hand"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}"
                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                        BorderThickness="{TemplateBinding BorderThickness}"
                                                        CornerRadius="3"
                                                        Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="Center"
                                                                      VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver"
                                                             Value="True">
                                                        <Setter Property="Background"
                                                                Value="#606060"/>
                                                    </Trigger>
                                                    <Trigger Property="IsPressed"
                                                             Value="True">
                                                        <Setter Property="Background"
                                                                Value="#2288CC"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Border.Resources>
                            <StackPanel Orientation="Vertical">
                                <!-- View preset row -->
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="Top"
                                            ToolTip="Top view (–Z)"
                                            Click="FF_ViewTop_Click"/>
                                    <Button Content="Bottom"
                                            ToolTip="Bottom view (+Z)"
                                            Click="FF_ViewBottom_Click"/>
                                    <Button Content="Front"
                                            ToolTip="Front view (–Y)"
                                            Click="FF_ViewFront_Click"/>
                                    <Button Content="Back"
                                            ToolTip="Back view (+Y)"
                                            Click="FF_ViewBack_Click"/>
                                    <Button Content="Left"
                                            ToolTip="Left view (–X)"
                                            Click="FF_ViewLeft_Click"/>
                                    <Button Content="Right"
                                            ToolTip="Right view (+X)"
                                            Click="FF_ViewRight_Click"/>
                                </StackPanel>
                                <!-- Zoom row -->
                                <StackPanel Orientation="Horizontal"
                                            HorizontalAlignment="Center">
                                    <Button Content="＋ Zoom In"
                                            ToolTip="Zoom in"
                                            Click="FF_ZoomIn_Click"/>
                                    <Button Content="－ Zoom Out"
                                            ToolTip="Zoom out"
                                            Click="FF_ZoomOut_Click"/>
                                    <Button Content="⛶ Fit"
                                            ToolTip="Zoom fit"
                                            Click="FF_ZoomFit_Click"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <h:HelixViewport3D x:Name="Viewport3D"
                                           Background="White"
                                           ShowCoordinateSystem="True"
                                           CoordinateSystemLabelForeground="Gray"
                                           ZoomExtentsWhenLoaded="True"
                                           ShowViewCube="True"
                                           IsRotationEnabled="False"
                                           IsPanEnabled="False"
                                           IsZoomEnabled="False"
                                           InfoForeground="Gray">
                            <h:HelixViewport3D.Camera>
                                <PerspectiveCamera Position="2,2,1.5"
                                                   LookDirection="-2,-2,-1.5"
                                                   UpDirection="0,0,1"
                                                   FieldOfView="45"/>
                            </h:HelixViewport3D.Camera>
                            <h:DefaultLights/>
                        </h:HelixViewport3D>
                    </Grid>
                </Border>
            </TabItem>
        </TabControl>

        <!-- Buttons -->
        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,10,0,0">
            <Button Content="Open Folder"
                    Width="100"
                    Height="30"
                    Margin="0,0,8,0"
                    Click="BtnOpenFolder_Click"/>
            <Button Content="Close"
                    Width="80"
                    Height="30"
                    Click="BtnClose_Click"/>
        </StackPanel>
    </Grid>
</Window>
