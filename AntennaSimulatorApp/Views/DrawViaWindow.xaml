<Window x:Class="AntennaSimulatorApp.Views.DrawViaWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:AntennaSimulatorApp.Views"
        Title="Draw Via"
        Width="780"
        Height="660"
        MinWidth="680"
        MinHeight="520"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip"
        ShowInTaskbar="False"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        PreviewKeyDown="Window_PreviewKeyDown">

        <Window.Resources>
                <Style TargetType="Button">
                        <Setter Property="Padding"
                                Value="8,3"/>
                        <Setter Property="Margin"
                                Value="3,2"/>
                        <Setter Property="MinWidth"
                                Value="60"/>
                </Style>
                <Style TargetType="Label">
                        <Setter Property="VerticalAlignment"
                                Value="Center"/>
                        <Setter Property="Padding"
                                Value="4,0"/>
                </Style>
        </Window.Resources>

        <DockPanel Margin="10">

                <!-- ── Bottom: Save/Open + OK / Cancel ─────────────────────────── -->
                <Grid DockPanel.Dock="Bottom"
                      Margin="0,6,0,0">
                        <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0"
                                    Orientation="Horizontal">
                                <Button Content="💾 Save"
                                        Click="SaveViaList_Click"
                                        ToolTip="Save via list to .vialist file"/>
                                <Button Content="📂 Open"
                                        Click="OpenViaList_Click"
                                        ToolTip="Load via list from .vialist file"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2"
                                    Orientation="Horizontal">
                                <Button x:Name="OkButton"
                                        Content="OK"
                                        IsDefault="True"
                                        Click="OkButton_Click"
                                        Background="#BBDDBB"/>
                                <Button Content="Cancel"
                                        IsCancel="True"
                                        Click="CancelButton_Click"/>
                        </StackPanel>
                </Grid>

                <!-- ── Main content: left list + right preview ─────────────────── -->
                <Grid>
                        <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="380"/>
                                <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- ── Left panel: via list + editor ── -->
                        <DockPanel Grid.Column="0"
                                   Margin="0,0,8,0">

                                <!-- Toolbar -->
                                <StackPanel DockPanel.Dock="Top"
                                            Orientation="Horizontal"
                                            Margin="0,0,0,4">
                                        <Button Content="＋ Add Via"
                                                Click="AddVia_Click"
                                                ToolTip="Add a new via"/>
                                        <Button Content="✕ Delete"
                                                Click="DeleteVia_Click"
                                                ToolTip="Delete selected via"/>
                                        <Button Content="📋 Copy"
                                                Click="CopyVia_Click"
                                                ToolTip="Copy selected vias (Ctrl+C)"/>
                                        <Button Content="📌 Paste"
                                                Click="PasteVia_Click"
                                                ToolTip="Paste copied vias (Ctrl+V)"/>
                                </StackPanel>

                                <!-- Via list -->
                                <DataGrid x:Name="ViaGrid"
                                          DockPanel.Dock="Top"
                                          Height="160"
                                          AutoGenerateColumns="False"
                                          CanUserAddRows="False"
                                          SelectionMode="Single"
                                          SelectionChanged="ViaGrid_SelectionChanged"
                                          HeadersVisibility="Column"
                                          GridLinesVisibility="Horizontal"
                                          IsReadOnly="True"
                                          Margin="0,0,0,6">
                                        <DataGrid.Columns>
                                                <DataGridTextColumn Header="Name"
                                                                    Binding="{Binding Name}"
                                                                    Width="80"/>
                                                <DataGridTextColumn Header="Board"
                                                                    Binding="{Binding IsCarrier, Converter={x:Static local:ViaWindow_BoardConverter.Instance}}"
                                                                    Width="60"/>
                                                <DataGridTextColumn Header="From"
                                                                    Binding="{Binding FromLayer}"
                                                                    Width="65"/>
                                                <DataGridTextColumn Header="To"
                                                                    Binding="{Binding ToLayer}"
                                                                    Width="65"/>
                                                <DataGridTextColumn Header="⌀ (mil)"
                                                                    Binding="{Binding DiameterMil, StringFormat=F1}"
                                                                    Width="55"/>
                                                <DataGridTextColumn Header="X (mm)"
                                                                    Binding="{Binding X, StringFormat=F2}"
                                                                    Width="55"/>
                                                <DataGridTextColumn Header="Y (mm)"
                                                                    Binding="{Binding Y, StringFormat=F2}"
                                                                    Width="55"/>
                                        </DataGrid.Columns>
                                </DataGrid>

                                <!-- ── Editor for selected via ── -->
                                <GroupBox Header="Via Properties"
                                          Padding="6">
                                        <Grid x:Name="EditorPanel">
                                                <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>
                                                <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>

                                                <!-- Row 0: Name + Board -->
                                                <Label Content="Name:"
                                                       Grid.Row="0"
                                                       Grid.Column="0"/>
                                                <TextBox x:Name="ViaNameBox"
                                                         Grid.Row="0"
                                                         Grid.Column="1"
                                                         Margin="2"
                                                         VerticalAlignment="Center"
                                                         TextChanged="ViaProperty_Changed"/>

                                                <Label Content="Board:"
                                                       Grid.Row="0"
                                                       Grid.Column="2"/>
                                                <ComboBox x:Name="BoardCombo"
                                                          Grid.Row="0"
                                                          Grid.Column="3"
                                                          Margin="2"
                                                          VerticalAlignment="Center"
                                                          SelectionChanged="BoardCombo_SelectionChanged"/>

                                                <!-- Row 1: From Layer + To Layer -->
                                                <Label Content="From Layer:"
                                                       Grid.Row="1"
                                                       Grid.Column="0"/>
                                                <ComboBox x:Name="FromLayerCombo"
                                                          Grid.Row="1"
                                                          Grid.Column="1"
                                                          Margin="2"
                                                          VerticalAlignment="Center"
                                                          DisplayMemberPath="Name"
                                                          SelectionChanged="LayerCombo_SelectionChanged"/>

                                                <Label Content="To Layer:"
                                                       Grid.Row="1"
                                                       Grid.Column="2"/>
                                                <ComboBox x:Name="ToLayerCombo"
                                                          Grid.Row="1"
                                                          Grid.Column="3"
                                                          Margin="2"
                                                          VerticalAlignment="Center"
                                                          DisplayMemberPath="Name"
                                                          SelectionChanged="LayerCombo_SelectionChanged"/>

                                                <!-- Row 2: Diameter -->
                                                <Label Content="Diameter:"
                                                       Grid.Row="2"
                                                       Grid.Column="0"/>
                                                <Grid Grid.Row="2"
                                                      Grid.Column="1"
                                                      Grid.ColumnSpan="3">
                                                        <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="80"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBox x:Name="DiameterBox"
                                                                 Grid.Column="0"
                                                                 Margin="2"
                                                                 VerticalAlignment="Center"
                                                                 TextChanged="ViaProperty_Changed"/>
                                                        <TextBlock Text="mil"
                                                                   Grid.Column="1"
                                                                   VerticalAlignment="Center"
                                                                   Margin="4,0,0,0"/>
                                                </Grid>

                                                <!-- Row 3: Position X, Y -->
                                                <Label Content="X (mm):"
                                                       Grid.Row="3"
                                                       Grid.Column="0"/>
                                                <TextBox x:Name="PosXBox"
                                                         Grid.Row="3"
                                                         Grid.Column="1"
                                                         Margin="2"
                                                         VerticalAlignment="Center"
                                                         TextChanged="ViaProperty_Changed"/>

                                                <Label Content="Y (mm):"
                                                       Grid.Row="3"
                                                       Grid.Column="2"/>
                                                <TextBox x:Name="PosYBox"
                                                         Grid.Row="3"
                                                         Grid.Column="3"
                                                         Margin="2"
                                                         VerticalAlignment="Center"
                                                         TextChanged="ViaProperty_Changed"/>

                                                <!-- Row 4: Board bounds hint -->
                                                <TextBlock x:Name="BoundsHint"
                                                           Grid.Row="4"
                                                           Grid.Column="0"
                                                           Grid.ColumnSpan="4"
                                                           FontStyle="Italic"
                                                           Foreground="#666"
                                                           Margin="4,6,0,0"
                                                           TextWrapping="Wrap"/>
                                        </Grid>
                                </GroupBox>
                        </DockPanel>

                        <!-- ── Right panel: 2D top-view preview ── -->
                        <GroupBox Grid.Column="1"
                                  Header="Top View Preview (X-Y plane)"
                                  Padding="4">
                                <DockPanel>
                                        <!-- Board selector for preview -->
                                        <StackPanel DockPanel.Dock="Top"
                                                    Orientation="Horizontal"
                                                    Margin="0,0,0,4">
                                                <Label Content="Display Board:"
                                                       Padding="4,0"/>
                                                <ComboBox x:Name="PreviewBoardCombo"
                                                          Width="100"
                                                          SelectionChanged="PreviewBoardCombo_SelectionChanged">
                                                        <ComboBoxItem Content="Carrier"
                                                                      IsSelected="True"/>
                                                        <ComboBoxItem Content="Module"/>
                                                </ComboBox>
                                        </StackPanel>
                                        <!-- Navigation toolbar -->
                                        <StackPanel DockPanel.Dock="Bottom"
                                                    Orientation="Horizontal"
                                                    HorizontalAlignment="Center"
                                                    Margin="0,4,0,0">
                                                <Button Content="🔍＋"
                                                        Click="ZoomIn_Click"
                                                        ToolTip="Zoom In (scroll up)"
                                                        MinWidth="36"
                                                        Padding="4,2"/>
                                                <Button Content="🔍－"
                                                        Click="ZoomOut_Click"
                                                        ToolTip="Zoom Out (scroll down)"
                                                        MinWidth="36"
                                                        Padding="4,2"/>
                                                <Button Content="⟵"
                                                        Click="PanLeft_Click"
                                                        ToolTip="Pan Left (← / Shift+scroll up)"
                                                        MinWidth="30"
                                                        Padding="4,2"/>
                                                <Button Content="⟶"
                                                        Click="PanRight_Click"
                                                        ToolTip="Pan Right (→ / Shift+scroll down)"
                                                        MinWidth="30"
                                                        Padding="4,2"/>
                                                <Button Content="⟰"
                                                        Click="PanUp_Click"
                                                        ToolTip="Pan Up (↑ / Ctrl+scroll up)"
                                                        MinWidth="30"
                                                        Padding="4,2"/>
                                                <Button Content="⟱"
                                                        Click="PanDown_Click"
                                                        ToolTip="Pan Down (↓ / Ctrl+scroll down)"
                                                        MinWidth="30"
                                                        Padding="4,2"/>
                                                <Button Content="Fit"
                                                        Click="FitView_Click"
                                                        ToolTip="Reset to fit all"
                                                        MinWidth="36"
                                                        Padding="4,2"/>
                                        </StackPanel>
                                        <Canvas x:Name="PreviewCanvas"
                                                Background="White"
                                                ClipToBounds="True"
                                                Focusable="True"
                                                SizeChanged="PreviewCanvas_SizeChanged"
                                                MouseWheel="PreviewCanvas_MouseWheel"/>
                                </DockPanel>
                        </GroupBox>
                </Grid>
        </DockPanel>
</Window>
