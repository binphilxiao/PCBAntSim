<Window x:Class="AntennaSimulatorApp.Views.MicrostripCalcWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Microstrip Impedance Calculator"
        Width="780"
        Height="560"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip"
        Background="#F5F5F5">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="300"/>
        </Grid.ColumnDefinitions>

        <!-- Microstrip Cross-Section Diagram -->
        <Border Grid.Column="0"
                Margin="8"
                Background="White"
                BorderBrush="#CCC"
                BorderThickness="1"
                CornerRadius="4">
            <Canvas x:Name="DiagramCanvas"
                    ClipToBounds="True"
                    SizeChanged="DiagramCanvas_SizeChanged"/>
        </Border>

        <!-- Right Panel -->
        <ScrollViewer Grid.Column="1"
                      VerticalScrollBarVisibility="Auto"
                      Margin="0,8,8,8">
            <StackPanel Margin="4">

                <!-- Board Selection -->
                <GroupBox Header="PCB Board"
                          Margin="0,0,0,8">
                    <StackPanel Margin="4">
                        <RadioButton x:Name="RbCarrier"
                                     Content="Carrier Board"
                                     IsChecked="True"
                                     Checked="OnBoardChanged"
                                     Margin="0,2"/>
                        <RadioButton x:Name="RbModule"
                                     Content="Module Board"
                                     Checked="OnBoardChanged"
                                     Margin="0,4"/>
                        <Separator Margin="0,6"/>
                        <TextBlock x:Name="TxtBoardInfo"
                                   Text="—"
                                   Foreground="#555"
                                   TextWrapping="Wrap"
                                   FontSize="11"
                                   Margin="0,2"/>
                    </StackPanel>
                </GroupBox>

                <!-- Substrate Parameters (from stackup, editable) -->
                <GroupBox Header="Substrate Parameters"
                          Margin="0,0,0,8">
                    <StackPanel Margin="4">
                        <DockPanel Margin="0,2">
                            <TextBlock Text="εr:"
                                       Width="90"
                                       VerticalAlignment="Center"/>
                            <TextBox x:Name="TxtEr"
                                     Text="4.3"
                                     Width="80"
                                     HorizontalAlignment="Left"
                                     TextChanged="OnParamChanged"/>
                        </DockPanel>
                        <DockPanel Margin="0,4">
                            <TextBlock Text="H (mm):"
                                       Width="90"
                                       VerticalAlignment="Center"
                                       ToolTip="Dielectric height between top copper and ground plane"/>
                            <TextBox x:Name="TxtH"
                                     Text="0.2"
                                     Width="80"
                                     HorizontalAlignment="Left"
                                     TextChanged="OnParamChanged"/>
                        </DockPanel>
                        <DockPanel Margin="0,4">
                            <TextBlock Text="T (mm):"
                                       Width="90"
                                       VerticalAlignment="Center"
                                       ToolTip="Copper thickness"/>
                            <TextBox x:Name="TxtT"
                                     Text="0.035"
                                     Width="80"
                                     HorizontalAlignment="Left"
                                     TextChanged="OnParamChanged"/>
                        </DockPanel>
                    </StackPanel>
                </GroupBox>

                <!-- Impedance Target -->
                <GroupBox Header="Target Impedance"
                          Margin="0,0,0,8">
                    <StackPanel Margin="4">
                        <DockPanel Margin="0,2">
                            <TextBlock Text="Z₀ (Ω):"
                                       Width="90"
                                       VerticalAlignment="Center"/>
                            <TextBox x:Name="TxtTargetZ"
                                     Text="50"
                                     Width="80"
                                     HorizontalAlignment="Left"
                                     TextChanged="OnParamChanged"/>
                        </DockPanel>
                        <DockPanel Margin="0,4">
                            <TextBlock Text="Freq (GHz):"
                                       Width="90"
                                       VerticalAlignment="Center"/>
                            <TextBox x:Name="TxtFreq"
                                     Text="2.45"
                                     Width="80"
                                     HorizontalAlignment="Left"
                                     TextChanged="OnParamChanged"/>
                        </DockPanel>
                    </StackPanel>
                </GroupBox>

                <!-- Results -->
                <GroupBox Header="Results"
                          Margin="0,0,0,8">
                    <StackPanel Margin="4">
                        <TextBlock x:Name="TxtResultW"
                                   Text="W = —"
                                   FontFamily="Consolas"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Margin="0,2"/>
                        <TextBlock x:Name="TxtResultZ"
                                   Text="Z₀ = —"
                                   FontFamily="Consolas"
                                   FontSize="12"
                                   Margin="0,2"/>
                        <TextBlock x:Name="TxtResultEeff"
                                   Text="εeff = —"
                                   FontFamily="Consolas"
                                   FontSize="12"
                                   Margin="0,2"/>
                        <TextBlock x:Name="TxtResultVp"
                                   Text="vp = —"
                                   FontFamily="Consolas"
                                   FontSize="12"
                                   Margin="0,2"/>
                        <TextBlock x:Name="TxtResultLambda"
                                   Text="λ/4 = —"
                                   FontFamily="Consolas"
                                   FontSize="12"
                                   Margin="0,2"/>
                        <Separator Margin="0,6"/>
                        <TextBlock x:Name="TxtResultWH"
                                   Text="W/H = —"
                                   FontFamily="Consolas"
                                   FontSize="11"
                                   Foreground="#555"
                                   Margin="0,2"/>
                    </StackPanel>
                </GroupBox>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
