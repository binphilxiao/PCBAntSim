<Window x:Class="AntennaSimulatorApp.Views.FieldResultWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Field Distribution"
        Width="900"
        Height="720"
        MinWidth="600"
        MinHeight="480"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="True">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Info bar -->
        <Border Grid.Row="0"
                Background="#F0F4F8"
                CornerRadius="4"
                Padding="12,8"
                Margin="0,0,0,8">
            <TextBlock x:Name="TxtInfo"
                       Text="Field distribution at center frequency"
                       FontSize="13"
                       FontWeight="SemiBold"/>
        </Border>

        <!-- Tabs for each field -->
        <TabControl Grid.Row="1"
                    x:Name="FieldTabs">
            <TabItem x:Name="TabJ"
                     Header="Surface Current (J)"
                     Visibility="Collapsed">
                <ScrollViewer HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Auto">
                    <Image x:Name="ImgJ"
                           Stretch="Uniform"
                           RenderOptions.BitmapScalingMode="HighQuality"/>
                </ScrollViewer>
            </TabItem>
            <TabItem x:Name="TabE"
                     Header="E-Field"
                     Visibility="Collapsed">
                <ScrollViewer HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Auto">
                    <Image x:Name="ImgE"
                           Stretch="Uniform"
                           RenderOptions.BitmapScalingMode="HighQuality"/>
                </ScrollViewer>
            </TabItem>
            <TabItem x:Name="TabH"
                     Header="H-Field"
                     Visibility="Collapsed">
                <ScrollViewer HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Auto">
                    <Image x:Name="ImgH"
                           Stretch="Uniform"
                           RenderOptions.BitmapScalingMode="HighQuality"/>
                </ScrollViewer>
            </TabItem>
        </TabControl>

        <!-- Bottom button bar -->
        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,8,0,0">
            <Button Content="Refresh"
                    Width="80"
                    Height="28"
                    Click="BtnRefresh_Click"
                    Margin="0,0,8,0"/>
            <Button Content="Close"
                    Width="80"
                    Height="28"
                    Click="BtnClose_Click"/>
        </StackPanel>
    </Grid>
</Window>
