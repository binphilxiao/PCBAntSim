<Window x:Class="AntennaSimulatorApp.Views.OptionsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Options"
        Width="600"
        Height="260"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="130"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="80"/>
        </Grid.ColumnDefinitions>

        <!-- openEMS path -->
        <Label Grid.Row="0"
                Grid.Column="0"
                Content="openEMS path:"
                VerticalAlignment="Center"/>
        <TextBox Grid.Row="0"
                Grid.Column="1"
                x:Name="OpenEmsPathBox"
                 VerticalAlignment="Center"
                Margin="0,0,8,0"/>
        <Button Grid.Row="0"
                Grid.Column="2"
                Content="Browse…"
                Click="BrowseOpenEms_Click"
                VerticalAlignment="Center"/>

        <TextBlock Grid.Row="2"
                Grid.Column="1"
                Grid.ColumnSpan="2"
                   Foreground="#888"
                FontStyle="Italic"
                TextWrapping="Wrap"
                   Text="Folder containing openEMS.exe (e.g. C:\openEMS\openEMS). Leave empty for auto-detect."/>

        <!-- Python path -->
        <Label Grid.Row="4"
                Grid.Column="0"
                Content="Python path:"
                VerticalAlignment="Center"/>
        <TextBox Grid.Row="4"
                Grid.Column="1"
                x:Name="PythonPathBox"
                 VerticalAlignment="Center"
                Margin="0,0,8,0"/>
        <Button Grid.Row="4"
                Grid.Column="2"
                Content="Browse…"
                Click="BrowsePython_Click"
                VerticalAlignment="Center"/>

        <!-- OK / Cancel -->
        <StackPanel Grid.Row="6"
                Grid.Column="0"
                Grid.ColumnSpan="3"
                    Orientation="Horizontal"
                HorizontalAlignment="Right">
            <Button Content="OK"
                    Width="80"
                    Margin="0,0,8,0"
                    IsDefault="True"
                    Click="OK_Click"/>
            <Button Content="Cancel"
                    Width="80"
                    IsCancel="True"
                    Click="Cancel_Click"/>
        </StackPanel>
    </Grid>
</Window>
