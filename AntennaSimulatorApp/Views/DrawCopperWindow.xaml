<Window x:Class="AntennaSimulatorApp.Views.DrawCopperWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Draw Copper"
        Width="580"
        Height="640"
        MinWidth="440"
        MinHeight="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip"
        ShowInTaskbar="False"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">

        <Window.Resources>
                <Style TargetType="Button">
                        <Setter Property="Padding"
                                Value="8,3"/>
                        <Setter Property="Margin"
                                Value="3,2"/>
                        <Setter Property="MinWidth"
                                Value="60"/>
                </Style>
                <Style TargetType="Label">
                        <Setter Property="VerticalAlignment"
                                Value="Center"/>
                        <Setter Property="Padding"
                                Value="4,0"/>
                </Style>
        </Window.Resources>

        <DockPanel Margin="10">

                <!-- ── Bottom: status + OK / Cancel ────────────────────────── -->
                <Grid DockPanel.Dock="Bottom"
                      Margin="0,6,0,0">
                        <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Left: Save / Open -->
                        <StackPanel Grid.Column="0"
                                    Orientation="Horizontal">
                                <Button Content="💾 Save"
                                        Click="SaveShape_Click"
                                        ToolTip="Save copper shape to .coppershape file"/>
                                <Button Content="📂 Open"
                                        Click="OpenShape_Click"
                                        ToolTip="Load copper shape from .coppershape file"/>
                        </StackPanel>

                        <!-- Right: status + action buttons -->
                        <StackPanel Grid.Column="2"
                                    Orientation="Horizontal">
                                <TextBlock x:Name="StatusText"
                                           VerticalAlignment="Center"
                                           Margin="0,0,12,0"
                                           FontStyle="Italic"
                                           Foreground="#555"/>
                                <Button x:Name="ValidateButton"
                                        Content="Validate"
                                        Click="ValidateButton_Click"
                                        ToolTip="Check polygon for errors"/>
                                <Button x:Name="OkButton"
                                        Content="OK"
                                        IsDefault="True"
                                        Click="OkButton_Click"
                                        Background="#BBDDBB"/>
                                <Button Content="Cancel"
                                        IsCancel="True"
                                        Click="CancelButton_Click"/>
                        </StackPanel>
                </Grid>

                <!-- ── Row 1: Name / Board / Layer / Show-in-3D ─────────────── -->
                <Grid DockPanel.Dock="Top"
                      Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="110"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="130"/>
                                <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Label Content="Name:"
                               Grid.Column="0"/>
                        <TextBox x:Name="NameBox"
                                 Grid.Column="1"
                                 Margin="2"
                                 VerticalAlignment="Center"
                                 Text="Shape"/>

                        <Label Content="Board:"
                               Grid.Column="2"/>
                        <ComboBox x:Name="BoardCombo"
                                  Grid.Column="3"
                                  Margin="2"
                                  VerticalAlignment="Center"
                                  SelectionChanged="BoardCombo_SelectionChanged"/>

                        <Label Content="Layer:"
                               Grid.Column="4"/>
                        <ComboBox x:Name="LayerCombo"
                                  Grid.Column="5"
                                  Margin="2"
                                  VerticalAlignment="Center"
                                  DisplayMemberPath="Name"/>


                </Grid>

                <!-- ── Row 2: Board-bounds hint ─────────────────────────────── -->
                <TextBlock x:Name="BoundsHint"
                           DockPanel.Dock="Top"
                           Margin="4,0,0,4"
                           FontSize="11"
                           Foreground="#666"
                           Text="X: [-W, 0]   Y: [-H/2, H/2]"/>

                <!-- ── Row 3: 2-D preview + vertex list (side by side) ──────── -->
                <Grid DockPanel.Dock="Top"
                      Margin="0,0,0,4"
                      Height="200">
                        <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="200"/>
                        </Grid.ColumnDefinitions>

                        <!-- 2D preview -->
                        <GroupBox Header="Preview (2D)"
                                  Grid.Column="0"
                                  Padding="4"
                                  Margin="0,0,4,0">
                                <Border Background="#F4F6FA"
                                        BorderBrush="#CCC"
                                        BorderThickness="1">
                                        <Canvas x:Name="PreviewCanvas2D"
                                                ClipToBounds="True"
                                                UseLayoutRounding="True"
                                                SnapsToDevicePixels="True"
                                                RenderOptions.EdgeMode="Unspecified"
                                                SizeChanged="PreviewCanvas2D_SizeChanged"/>
                                </Border>
                        </GroupBox>

                        <!-- Quick vertex summary -->
                        <GroupBox Header="Vertex Summary"
                                  Grid.Column="1"
                                  Padding="4">
                                <ListBox x:Name="VertexSummaryList"
                                         FontSize="10"
                                         IsHitTestVisible="False"/>
                        </GroupBox>
                </Grid>

                <!-- ── Row 4: Vertex editor ──────────────────────────────────── -->
                <GroupBox Header="Polygon Vertices  (mm)  — first = last to close"
                          DockPanel.Dock="Top"
                          Padding="5"
                          Margin="0,0,0,0">
                        <Grid>
                                <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <DataGrid x:Name="VertexGrid"
                                          Grid.Column="0"
                                          AutoGenerateColumns="False"
                                          CanUserAddRows="True"
                                          CanUserDeleteRows="True"
                                          CanUserReorderColumns="False"
                                          CanUserResizeRows="False"
                                          HeadersVisibility="Column"
                                          SelectionMode="Single"
                                          Margin="0,0,4,0"
                                          CellEditEnding="VertexGrid_CellEditEnding">
                                        <DataGrid.Columns>
                                                <DataGridTextColumn Header="X (mm)"
                                                                    Width="*"
                                                                    Binding="{Binding X, StringFormat=F4, UpdateSourceTrigger=LostFocus}"/>
                                                <DataGridTextColumn Header="Y (mm)"
                                                                    Width="*"
                                                                    Binding="{Binding Y, StringFormat=F4, UpdateSourceTrigger=LostFocus}"/>
                                        </DataGrid.Columns>
                                </DataGrid>

                                <StackPanel Grid.Column="1"
                                            VerticalAlignment="Top"
                                            Margin="0,2,0,0">
                                        <Button Content="Add"
                                                Click="AddVertex_Click"
                                                ToolTip="Insert a new (0,0) vertex after the selected row"/>
                                        <Button Content="Delete"
                                                Click="DeleteVertex_Click"
                                                ToolTip="Remove selected vertex"/>
                                        <Separator Margin="2,4"/>
                                        <Button Content="↑ Up"
                                                Click="MoveUp_Click"
                                                ToolTip="Move vertex up"/>
                                        <Button Content="↓ Down"
                                                Click="MoveDown_Click"
                                                ToolTip="Move vertex down"/>
                                        <Separator Margin="2,4"/>
                                        <Button Content="Close"
                                                Click="ClosePolygon_Click"
                                                Width="64"
                                                ToolTip="Copy first vertex to last to close the polygon"/>
                                </StackPanel>
                        </Grid>
                </GroupBox>

        </DockPanel>
</Window>
