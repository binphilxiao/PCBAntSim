<Window x:Class="AntennaSimulatorApp.Views.SimTypeDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Select Simulation Type"
        Width="400"
        Height="380"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Select simulation outputs:"
                   FontSize="13"
                   FontWeight="SemiBold"
                   Margin="0,0,0,12"/>

        <StackPanel Grid.Row="1"
                    Margin="10,0,0,0">
            <TextBlock Text="Analysis:"
                       FontSize="12"
                       FontWeight="SemiBold"
                       Margin="0,0,0,6"/>
            <CheckBox x:Name="ChkS11"
                      Content="S11 (Return Loss)"
                      FontSize="12"
                      IsChecked="True"
                      Margin="0,0,0,6"/>
            <CheckBox x:Name="ChkFarField"
                      Content="Far-Field (Pattern / Gain)"
                      FontSize="12"
                      Margin="0,0,0,12"/>

            <TextBlock Text="Field Dumps:"
                       FontSize="12"
                       FontWeight="SemiBold"
                       Margin="0,0,0,6"/>
            <CheckBox x:Name="ChkDumpJ"
                      Content="Surface Current (J) — check current path"
                      FontSize="11.5"
                      Margin="0,0,0,4"/>
            <CheckBox x:Name="ChkDumpE"
                      Content="Electric Field (E) — capacitive energy"
                      FontSize="11.5"
                      Margin="0,0,0,4"/>
            <CheckBox x:Name="ChkDumpH"
                      Content="Magnetic Field (H) — inductive energy"
                      FontSize="11.5"
                      Margin="0,0,0,8"/>

            <Separator Margin="0,0,0,8"/>
            <CheckBox x:Name="ChkOverlayOutline"
                      Content="Overlay antenna/copper outlines on plots"
                      FontSize="11.5"
                      IsChecked="True"
                      Margin="0,0,0,4"/>
        </StackPanel>

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Content="Run Simulation"
                    Width="100"
                    Height="30"
                    IsDefault="True"
                    Click="BtnOk_Click"
                    Margin="0,0,8,0"/>
            <Button Content="Cancel"
                    Width="80"
                    Height="30"
                    IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
