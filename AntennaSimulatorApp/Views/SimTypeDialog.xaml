<Window x:Class="AntennaSimulatorApp.Views.SimTypeDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Select Simulation Type"
        Width="380"
        Height="260"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Select the simulation analysis type:"
                   FontSize="13"
                   FontWeight="SemiBold"
                   Margin="0,0,0,16"/>

        <StackPanel Grid.Row="1"
                    Margin="10,0,0,16">
            <RadioButton x:Name="RbS11"
                         Content="S11 Only (Return Loss)"
                         FontSize="12"
                         IsChecked="True"
                         Margin="0,0,0,10"/>
            <RadioButton x:Name="RbFarField"
                         Content="Far-Field Only (Pattern / Gain)"
                         FontSize="12"
                         Margin="0,0,0,10"/>
            <RadioButton x:Name="RbBoth"
                         Content="S11 + Far-Field (Full Simulation)"
                         FontSize="12"
                         Margin="0,0,0,10"/>
        </StackPanel>

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Content="Run Simulation"
                    Width="100"
                    Height="30"
                    IsDefault="True"
                    Click="BtnOk_Click"
                    Margin="0,0,8,0"/>
            <Button Content="Cancel"
                    Width="80"
                    Height="30"
                    IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
