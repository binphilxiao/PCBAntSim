<Window x:Class="AntennaSimulatorApp.Views.S11ResultWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="S11 Results"
        Width="900"
        Height="620"
        MinWidth="600"
        MinHeight="400"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="True">

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Key metrics bar -->
        <Border Grid.Row="0"
                Background="#F0F4F8"
                CornerRadius="4"
                Padding="12,8"
                Margin="0,0,0,10">
            <DockPanel>
                <TextBlock x:Name="TxtLiveStatus"
                           DockPanel.Dock="Right"
                           Text=""
                           Foreground="#1565C0"
                           FontSize="11"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           Margin="8,0,0,0"/>
                <WrapPanel>
                    <StackPanel Orientation="Horizontal"
                                Margin="0,0,24,0">
                        <TextBlock Text="Resonance: "
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                        <TextBlock x:Name="TxtResonance"
                                   Text="—"
                                   FontSize="14"
                                   FontWeight="Bold"
                                   Foreground="#1565C0"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal"
                                Margin="0,0,24,0">
                        <TextBlock Text="Min S11: "
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                        <TextBlock x:Name="TxtMinS11"
                                   Text="—"
                                   FontSize="14"
                                   FontWeight="Bold"
                                   Foreground="#C62828"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal"
                                Margin="0,0,24,0">
                        <TextBlock Text="-10 dB BW: "
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                        <TextBlock x:Name="TxtBandwidth"
                                   Text="—"
                                   FontSize="14"
                                   FontWeight="Bold"
                                   Foreground="#2E7D32"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </WrapPanel>
            </DockPanel>
        </Border>

        <!-- Chart area -->
        <Border Grid.Row="1"
                BorderBrush="#CCC"
                BorderThickness="1"
                CornerRadius="3"
                Background="White"
                ClipToBounds="True">
            <!-- Chart drawn in code-behind on a Canvas -->
            <Canvas x:Name="ChartCanvas"
                    Background="White"
                    SizeChanged="ChartCanvas_SizeChanged"/>
        </Border>

        <!-- Buttons -->
        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,10,0,0">
            <Button Content="Open Folder"
                    Width="100"
                    Height="30"
                    Margin="0,0,8,0"
                    Click="BtnOpenFolder_Click"/>
            <Button Content="Close"
                    Width="80"
                    Height="30"
                    Click="BtnClose_Click"/>
        </StackPanel>
    </Grid>
</Window>
