<Window x:Class="AntennaSimulatorApp.Views.DrawSolderJointWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:AntennaSimulatorApp.Views"
        Title="Draw Solder Joint"
        Width="780"
        Height="660"
        MinWidth="680"
        MinHeight="520"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip"
        ShowInTaskbar="False"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        PreviewKeyDown="Window_PreviewKeyDown">

    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Padding"
                    Value="8,3"/>
            <Setter Property="Margin"
                    Value="3,2"/>
            <Setter Property="MinWidth"
                    Value="60"/>
        </Style>
        <Style TargetType="Label">
            <Setter Property="VerticalAlignment"
                    Value="Center"/>
            <Setter Property="Padding"
                    Value="4,0"/>
        </Style>
    </Window.Resources>

    <DockPanel Margin="10">

        <!-- ── Bottom: Save/Open + OK / Cancel ─────────────────────────── -->
        <Grid DockPanel.Dock="Bottom"
              Margin="0,6,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0"
                        Orientation="Horizontal">
                <Button Content="💾 Save"
                        Click="SaveList_Click"
                        ToolTip="Save solder joint list to .sjlist file"/>
                <Button Content="📂 Open"
                        Click="OpenList_Click"
                        ToolTip="Load solder joint list from .sjlist file"/>
            </StackPanel>
            <StackPanel Grid.Column="2"
                        Orientation="Horizontal">
                <Button x:Name="OkButton"
                        Content="OK"
                        IsDefault="True"
                        Click="OkButton_Click"
                        Background="#BBDDBB"/>
                <Button Content="Cancel"
                        IsCancel="True"
                        Click="CancelButton_Click"/>
            </StackPanel>
        </Grid>

        <!-- ── Main content: left list + right preview ─────────────────── -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="380"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ── Left panel: list + editor ── -->
            <DockPanel Grid.Column="0"
                       Margin="0,0,8,0">

                <!-- Info text -->
                <TextBlock DockPanel.Dock="Top"
                           Text="Solder joints connect the module board's bottom layer (top surface) to the carrier board's top layer (bottom surface)."
                           TextWrapping="Wrap"
                           FontStyle="Italic"
                           Foreground="#666"
                           Margin="0,0,0,6"/>

                <!-- Toolbar -->
                <StackPanel DockPanel.Dock="Top"
                            Orientation="Horizontal"
                            Margin="0,0,0,4">
                    <Button Content="＋ Add"
                            Click="AddItem_Click"
                            ToolTip="Add a new solder joint"/>
                    <Button Content="✕ Delete"
                            Click="DeleteItem_Click"
                            ToolTip="Delete selected solder joint"/>
                    <Button Content="📋 Copy"
                            Click="CopyItem_Click"
                            ToolTip="Copy selected (Ctrl+C)"/>
                    <Button Content="📌 Paste"
                            Click="PasteItem_Click"
                            ToolTip="Paste copied (Ctrl+V)"/>
                </StackPanel>

                <!-- List -->
                <DataGrid x:Name="ItemGrid"
                          DockPanel.Dock="Top"
                          Height="180"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          SelectionMode="Single"
                          SelectionChanged="ItemGrid_SelectionChanged"
                          HeadersVisibility="Column"
                          GridLinesVisibility="Horizontal"
                          IsReadOnly="True"
                          Margin="0,0,0,6">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Name"
                                            Binding="{Binding Name}"
                                            Width="100"/>
                        <DataGridTextColumn Header="⌀ (mil)"
                                            Binding="{Binding DiameterMil, StringFormat=F1}"
                                            Width="65"/>
                        <DataGridTextColumn Header="X (mm)"
                                            Binding="{Binding X, StringFormat=F2}"
                                            Width="70"/>
                        <DataGridTextColumn Header="Y (mm)"
                                            Binding="{Binding Y, StringFormat=F2}"
                                            Width="70"/>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- ── Editor for selected item ── -->
                <GroupBox Header="Solder Joint Properties"
                          Padding="6">
                    <Grid x:Name="EditorPanel">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Row 0: Name -->
                        <Label Content="Name:"
                               Grid.Row="0"
                               Grid.Column="0"/>
                        <TextBox x:Name="NameBox"
                                 Grid.Row="0"
                                 Grid.Column="1"
                                 Grid.ColumnSpan="3"
                                 Margin="2"
                                 VerticalAlignment="Center"
                                 TextChanged="Property_Changed"/>

                        <!-- Row 1: Diameter -->
                        <Label Content="Diameter:"
                               Grid.Row="1"
                               Grid.Column="0"/>
                        <Grid Grid.Row="1"
                              Grid.Column="1"
                              Grid.ColumnSpan="3">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="DiameterBox"
                                     Grid.Column="0"
                                     Margin="2"
                                     VerticalAlignment="Center"
                                     TextChanged="Property_Changed"/>
                            <TextBlock Text="mil"
                                       Grid.Column="1"
                                       VerticalAlignment="Center"
                                       Margin="4,0,0,0"/>
                        </Grid>

                        <!-- Row 2: Position X, Y -->
                        <Label Content="X (mm):"
                               Grid.Row="2"
                               Grid.Column="0"/>
                        <TextBox x:Name="PosXBox"
                                 Grid.Row="2"
                                 Grid.Column="1"
                                 Margin="2"
                                 VerticalAlignment="Center"
                                 TextChanged="Property_Changed"/>

                        <Label Content="Y (mm):"
                               Grid.Row="2"
                               Grid.Column="2"/>
                        <TextBox x:Name="PosYBox"
                                 Grid.Row="2"
                                 Grid.Column="3"
                                 Margin="2"
                                 VerticalAlignment="Center"
                                 TextChanged="Property_Changed"/>

                        <!-- Row 3: Bounds hint -->
                        <TextBlock x:Name="BoundsHint"
                                   Grid.Row="3"
                                   Grid.Column="0"
                                   Grid.ColumnSpan="4"
                                   FontStyle="Italic"
                                   Foreground="#666"
                                   Margin="4,6,0,0"
                                   TextWrapping="Wrap"/>
                    </Grid>
                </GroupBox>
            </DockPanel>

            <!-- ── Right panel: 2D top-view preview ── -->
            <GroupBox Grid.Column="1"
                      Header="Top View Preview (X-Y plane)"
                      Padding="4">
                <DockPanel>
                    <!-- Navigation toolbar -->
                    <StackPanel DockPanel.Dock="Bottom"
                                Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                Margin="0,4,0,0">
                        <Button Content="🔍＋"
                                Click="ZoomIn_Click"
                                ToolTip="Zoom In (Shift+↑)"
                                MinWidth="36"
                                Padding="4,2"/>
                        <Button Content="🔍－"
                                Click="ZoomOut_Click"
                                ToolTip="Zoom Out (Shift+↓)"
                                MinWidth="36"
                                Padding="4,2"/>
                        <Button Content="⟵"
                                Click="PanLeft_Click"
                                ToolTip="Pan Left (←)"
                                MinWidth="30"
                                Padding="4,2"/>
                        <Button Content="⟶"
                                Click="PanRight_Click"
                                ToolTip="Pan Right (→)"
                                MinWidth="30"
                                Padding="4,2"/>
                        <Button Content="⟰"
                                Click="PanUp_Click"
                                ToolTip="Pan Up (↑)"
                                MinWidth="30"
                                Padding="4,2"/>
                        <Button Content="⟱"
                                Click="PanDown_Click"
                                ToolTip="Pan Down (↓)"
                                MinWidth="30"
                                Padding="4,2"/>
                        <Button Content="Fit"
                                Click="FitView_Click"
                                ToolTip="Reset to fit all"
                                MinWidth="36"
                                Padding="4,2"/>
                    </StackPanel>
                    <Canvas x:Name="PreviewCanvas"
                            Background="White"
                            ClipToBounds="True"
                            Focusable="True"
                            SizeChanged="PreviewCanvas_SizeChanged"
                            MouseWheel="PreviewCanvas_MouseWheel"/>
                </DockPanel>
            </GroupBox>
        </Grid>
    </DockPanel>
</Window>
