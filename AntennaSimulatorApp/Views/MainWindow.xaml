<Window x:Class="AntennaSimulatorApp.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AntennaSimulatorApp.Views"
        xmlns:conv="clr-namespace:AntennaSimulatorApp"
        xmlns:vm="clr-namespace:AntennaSimulatorApp.ViewModels"
        mc:Ignorable="d"
        Title="PCB Antenna Simulator"
        Height="800"
        Width="1200"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        xmlns:h="http://helix-toolkit.org/wpf"
        xmlns:models="clr-namespace:AntennaSimulatorApp.Models"
        PreviewKeyDown="Window_PreviewKeyDown">

    <Window.Resources>
        <conv:OffsetConverter x:Key="OffsetConverter"/>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <x:Static x:Key="MaterialPresets"
                  Member="models:MaterialInfo.All"/>
    </Window.Resources>

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Window.InputBindings>
        <KeyBinding Key="O"
                    Modifiers="Ctrl"
                    Command="{x:Static local:MainWindow.OpenCommand}"/>
        <KeyBinding Key="S"
                    Modifiers="Ctrl"
                    Command="{x:Static local:MainWindow.SaveCommand}"/>
        <KeyBinding Key="S"
                    Modifiers="Ctrl+Shift"
                    Command="{x:Static local:MainWindow.SaveAsCommand}"/>
        <KeyBinding Key="F5"
                    Command="{x:Static local:MainWindow.SimulateCommand}"/>
    </Window.InputBindings>

    <DockPanel>

        <!-- ── Menu bar ────────────────────────────────────────────────────── -->
        <Menu DockPanel.Dock="Top">

            <!-- File -->
            <MenuItem Header="_File">
                <MenuItem Header="_Open…"
                          Click="MenuOpen_Click"
                          InputGestureText="Ctrl+O"/>
                <MenuItem Header="_Save"
                          Click="MenuSave_Click"
                          InputGestureText="Ctrl+S"/>
                <MenuItem Header="Save _As…"
                          Click="MenuSaveAs_Click"
                          InputGestureText="Ctrl+Shift+S"/>
                <Separator/>
                <MenuItem Header="_Export">
                    <MenuItem Header=".stp / .step"
                              Click="MenuExportStep_Click"
                              ToolTip="Export 3D model to STEP CAD format"/>
                    <MenuItem Header="openEMS Simulation Files…"
                              Click="MenuExportOpenEms_Click"
                              ToolTip="Export geometry + Python script for openEMS FDTD simulation"/>
                </MenuItem>
                <Separator/>
                <MenuItem Header="E_xit"
                          Click="MenuExit_Click"
                          InputGestureText="Alt+F4"/>
            </MenuItem>

            <!-- Draw -->
            <MenuItem Header="_Draw">
                <MenuItem Header="Copper Shapes…"
                          Click="MenuDrawCopper_Click"
                          ToolTip="View, draw, edit or delete copper fill shapes"/>
                <MenuItem Header="Draw Antenna…"
                          Click="MenuDrawAntenna_Click"
                          ToolTip="Generate antenna traces using the parametric wizard"/>
                <MenuItem Header="Draw Via…"
                          Click="MenuDrawVia_Click"
                          ToolTip="Add, edit or delete plated through-hole vias"/>
                <MenuItem Header="Draw Solder Joint…"
                          Click="MenuDrawSolderJoint_Click"
                          ToolTip="Add, edit or delete solder joints between module and carrier"/>
            </MenuItem>

            <!-- Simulate -->
            <MenuItem Header="_Simulate">
                <MenuItem Header="_Run Simulation"
                          Click="MenuSimulate_Click"
                          InputGestureText="F5"/>
                <MenuItem Header="Simulation _Settings…"
                          Click="MenuSimSettings_Click"/>
                <Separator/>
                <MenuItem Header="View _Results">
                    <MenuItem Header="S11 Plot (Return Loss)"
                              Click="MenuViewS11_Click"/>
                    <MenuItem Header="Far-Field Pattern (2D / 3D)"
                              Click="MenuViewFarField_Click"/>
                    <MenuItem Header="Gain &amp; Directivity"
                              Click="MenuViewGain_Click"/>
                    <MenuItem Header="Antenna Efficiency"
                              Click="MenuViewEfficiency_Click"/>
                    <MenuItem Header="Surface Current Distribution"
                              Click="MenuViewCurrentDist_Click"/>
                    <MenuItem Header="Smith Chart"
                              Click="MenuViewSmith_Click"/>
                </MenuItem>
            </MenuItem>

            <!-- Tools -->
            <MenuItem Header="_Tools">
                <MenuItem Header="Microstrip Impedance Calculator…"
                          Click="MenuToolImpedance_Click"
                          ToolTip="Calculate characteristic impedance of microstrip / coplanar waveguide"/>
                <MenuItem Header="Frequency / Wavelength Converter…"
                          Click="MenuToolFreqWL_Click"
                          ToolTip="Convert between frequency and wavelength"/>
                <MenuItem Header="Skin Depth Calculator…"
                          Click="MenuToolSkinDepth_Click"
                          ToolTip="Calculate skin depth of a conductor at a given frequency"/>
                <MenuItem Header="Smith Chart (Impedance Matching)…"
                          Click="MenuToolSmithChart_Click"
                          ToolTip="Interactive Smith chart with L-network impedance matching calculator"/>
                <Separator/>
                <MenuItem Header="Options / Preferences…"
                          Click="MenuToolOptions_Click"/>
            </MenuItem>

            <!-- Help -->
            <MenuItem Header="_Help">
                <MenuItem Header="About / Version Info"
                          Click="MenuAbout_Click"/>
                <MenuItem Header="Check for Updates…"
                          Click="MenuCheckUpdate_Click"/>
                <Separator/>
                <MenuItem Header="Copyright Notice"
                          Click="MenuCopyright_Click"/>
            </MenuItem>

        </Menu>

        <!-- ── Toolbar ─────────────────────────────────────────────────────── -->
        <ToolBarTray DockPanel.Dock="Top"
                     Background="#F0F0F0">

            <!-- File -->
            <ToolBar Band="0"
                     BandIndex="0"
                     Header="File">
                <Button Click="MenuOpen_Click"
                        ToolTip="Open Project (Ctrl+O)"
                        Padding="6,2">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="📂"
                                   FontSize="14"
                                   Margin="0,0,4,0"/>
                        <TextBlock Text="Open"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button Click="MenuSave_Click"
                        ToolTip="Save Project (Ctrl+S)"
                        Padding="6,2">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="💾"
                                   FontSize="14"
                                   Margin="0,0,4,0"/>
                        <TextBlock Text="Save"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Separator/>
                <Button Click="MenuExportStep_Click"
                        ToolTip="Export to STEP"
                        Padding="6,2">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="📤"
                                   FontSize="14"
                                   Margin="0,0,4,0"/>
                        <TextBlock Text="STEP"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button Click="MenuExportOpenEms_Click"
                        ToolTip="Export openEMS Files"
                        Padding="6,2">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="📤"
                                   FontSize="14"
                                   Margin="0,0,4,0"/>
                        <TextBlock Text="openEMS"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </ToolBar>

            <!-- Draw -->
            <ToolBar Band="0"
                     BandIndex="1"
                     Header="Draw">
                <Button Click="MenuDrawCopper_Click"
                        ToolTip="Copper Shapes"
                        Padding="6,2">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="⬛"
                                   FontSize="14"
                                   Margin="0,0,4,0"
                                   Foreground="#CC7722"/>
                        <TextBlock Text="Copper"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button Click="MenuDrawAntenna_Click"
                        ToolTip="Draw Antenna"
                        Padding="6,2">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="📡"
                                   FontSize="14"
                                   Margin="0,0,4,0"/>
                        <TextBlock Text="Antenna"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button Click="MenuDrawVia_Click"
                        ToolTip="Draw Via"
                        Padding="6,2">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="⊕"
                                   FontSize="14"
                                   Margin="0,0,4,0"/>
                        <TextBlock Text="Via"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button Click="MenuDrawSolderJoint_Click"
                        ToolTip="Draw Solder Joint"
                        Padding="6,2">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="⊙"
                                   FontSize="14"
                                   Margin="0,0,4,0"/>
                        <TextBlock Text="Solder Joint"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </ToolBar>

            <!-- Simulate -->
            <ToolBar Band="0"
                     BandIndex="2"
                     Header="Simulate">
                <Button Click="MenuSimulate_Click"
                        ToolTip="Run Simulation (F5)"
                        Padding="6,2">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="▶"
                                   FontSize="14"
                                   Margin="0,0,4,0"
                                   Foreground="Green"/>
                        <TextBlock Text="Run"
                                   VerticalAlignment="Center"
                                   FontWeight="SemiBold"/>
                    </StackPanel>
                </Button>
                <Button Click="MenuSimSettings_Click"
                        ToolTip="Simulation Settings"
                        Padding="6,2">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="⚙"
                                   FontSize="14"
                                   Margin="0,0,4,0"/>
                        <TextBlock Text="Settings"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Separator/>
                <Button Click="MenuViewS11_Click"
                        ToolTip="View S11 Plot"
                        Padding="6,2">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="📈"
                                   FontSize="14"
                                   Margin="0,0,4,0"/>
                        <TextBlock Text="S11"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button Click="MenuViewSmith_Click"
                        ToolTip="View Smith Chart"
                        Padding="6,2">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="◎"
                                   FontSize="14"
                                   Margin="0,0,4,0"/>
                        <TextBlock Text="Smith"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </ToolBar>

            <!-- Tools -->
            <ToolBar Band="0"
                     BandIndex="3"
                     Header="Tools">
                <Button Click="MenuToolImpedance_Click"
                        ToolTip="Microstrip Impedance Calculator"
                        Padding="6,2">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Ω"
                                   FontSize="14"
                                   FontWeight="Bold"
                                   Margin="0,0,4,0"/>
                        <TextBlock Text="Impedance"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button Click="MenuToolSmithChart_Click"
                        ToolTip="Smith Chart Tool"
                        Padding="6,2">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="◎"
                                   FontSize="14"
                                   Margin="0,0,4,0"/>
                        <TextBlock Text="Smith Chart"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </ToolBar>

        </ToolBarTray>

        <Grid Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="430"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Configuration Panel -->
            <ScrollViewer Grid.Column="0">
                <StackPanel>

                    <!-- Carrier Board Settings -->
                    <GroupBox Header="Base Board"
                              Margin="0,0,0,10"
                              Padding="5">
                        <StackPanel>
                            <Grid Margin="0,2,0,2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Label Content="Length:"
                                       Grid.Column="0"
                                       VerticalAlignment="Center"
                                       Padding="3,0"/>
                                <TextBox Text="{Binding CarrierBoard.Width}"
                                         Grid.Column="1"
                                         Margin="2"
                                         VerticalAlignment="Center"/>
                                <Label Content="Width:"
                                       Grid.Column="2"
                                       VerticalAlignment="Center"
                                       Padding="3,0"/>
                                <TextBox Text="{Binding CarrierBoard.Height}"
                                         Grid.Column="3"
                                         Margin="2"
                                         VerticalAlignment="Center"/>
                            </Grid>

                            <Grid Margin="0,2,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="70"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Label Content="Thickness:"
                                       Grid.Column="0"
                                       VerticalAlignment="Center"
                                       Padding="3,0"/>
                                <TextBox Grid.Column="1"
                                         Text="{Binding CarrierBoard.Thickness, UpdateSourceTrigger=LostFocus}"
                                         Margin="2"
                                         VerticalAlignment="Center"/>
                                <TextBlock Text="mm"
                                           Grid.Column="2"
                                           VerticalAlignment="Center"
                                           Margin="2,0,8,0"/>
                                <Label Content="Layers:"
                                       Grid.Column="3"
                                       VerticalAlignment="Center"
                                       Padding="3,0"/>
                                <ComboBox Grid.Column="4"
                                          ItemsSource="{Binding AvailableLayerCounts}"
                                          SelectedItem="{Binding CarrierBoard.LayerCount}"
                                          VerticalAlignment="Center"
                                          Margin="2"/>
                            </Grid>

                            <Expander Header="Generated Stackup"
                                      Margin="0,5,0,0"
                                      IsExpanded="True">
                                <DataGrid ItemsSource="{Binding CarrierBoard.Stackup.Layers}"
                                          AutoGenerateColumns="False"
                                          MinHeight="200"
                                          MaxHeight="500"
                                          CanUserAddRows="True"
                                          HorizontalScrollBarVisibility="Hidden"
                                          VerticalScrollBarVisibility="Auto">
                                    <DataGrid.Columns>
                                        <DataGridTemplateColumn Header="Name"
                                                                Width="2*">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <StackPanel Orientation="Horizontal"
                                                                VerticalAlignment="Center">
                                                        <CheckBox IsChecked="{Binding IsVisible, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                                                  Margin="2,0,4,0"
                                                                  VerticalAlignment="Center"/>
                                                        <TextBlock Text="{Binding Name}"
                                                                   VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                            <DataGridTemplateColumn.CellEditingTemplate>
                                                <DataTemplate>
                                                    <StackPanel Orientation="Horizontal"
                                                                VerticalAlignment="Center">
                                                        <CheckBox IsChecked="{Binding IsVisible, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                                                  Margin="2,0,4,0"
                                                                  VerticalAlignment="Center"/>
                                                        <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                                                                 BorderThickness="0"
                                                                 VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellEditingTemplate>
                                        </DataGridTemplateColumn>
                                        <DataGridTextColumn Header="Thick(mm)"
                                                            Binding="{Binding Thickness}"
                                                            Width="*"/>
                                        <DataGridTextColumn Header="Type"
                                                            Binding="{Binding Type}"
                                                            Width="*"/>
                                        <DataGridComboBoxColumn Header="Material"
                                                                Width="2*"
                                                                DisplayMemberPath="DisplayName"
                                                                SelectedValuePath="Value"
                                                                SelectedValueBinding="{Binding Material, UpdateSourceTrigger=PropertyChanged}"
                                                                ItemsSource="{StaticResource MaterialPresets}"/>
                                        <DataGridTextColumn Header="Dk"
                                                            Width="40"
                                                            Binding="{Binding DielectricConstant, StringFormat='{}{0:0.##}'}"/>
                                        <DataGridTemplateColumn Header="Gerber / Align"
                                                                Width="3*">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <StackPanel Margin="2,1"
                                                                Visibility="{Binding IsConductive, Converter={StaticResource BoolToVis}}">
                                                        <!-- file picker row -->
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="{Binding GerberFileName}"
                                                                       FontSize="10"
                                                                       VerticalAlignment="Center"
                                                                       MaxWidth="75"
                                                                       TextTrimming="CharacterEllipsis"
                                                                       ToolTip="{Binding GerberFilePath}"/>
                                                            <Button Content="…"
                                                                    Tag="{Binding}"
                                                                    Click="GerberBrowse_Click"
                                                                    Padding="3,1"
                                                                    Margin="2,0"
                                                                    ToolTip="Assign Gerber file"/>
                                                            <Button Content="×"
                                                                    Tag="{Binding}"
                                                                    Click="GerberClear_Click"
                                                                    Padding="3,1"
                                                                    Visibility="{Binding HasGerber, Converter={StaticResource BoolToVis}}"
                                                                    ToolTip="Remove Gerber file"/>
                                                        </StackPanel>
                                                        <!-- X/Y offset + rotation (shown only when file is assigned) -->
                                                        <Grid Visibility="{Binding HasGerber, Converter={StaticResource BoolToVis}}"
                                                              Margin="0,2,0,1">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="44"/>
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Text="X:"
                                                                       Grid.Column="0"
                                                                       FontSize="10"
                                                                       VerticalAlignment="Center"
                                                                       ToolTip="Gerber X offset (mm)"/>
                                                            <TextBox Grid.Column="1"
                                                                     FontSize="10"
                                                                     Padding="1"
                                                                     Text="{Binding GerberOffsetX, UpdateSourceTrigger=LostFocus, StringFormat='{}{0:0.###}'}"
                                                                     ToolTip="X offset in mm"/>
                                                            <TextBlock Text="Y:"
                                                                       Grid.Column="2"
                                                                       FontSize="10"
                                                                       VerticalAlignment="Center"
                                                                       Margin="3,0,0,0"
                                                                       ToolTip="Gerber Y offset (mm)"/>
                                                            <TextBox Grid.Column="3"
                                                                     FontSize="10"
                                                                     Padding="1"
                                                                     Text="{Binding GerberOffsetY, UpdateSourceTrigger=LostFocus, StringFormat='{}{0:0.###}'}"
                                                                     ToolTip="Y offset in mm"/>
                                                            <TextBlock Text="°:"
                                                                       Grid.Column="4"
                                                                       FontSize="10"
                                                                       VerticalAlignment="Center"
                                                                       Margin="3,0,0,0"
                                                                       ToolTip="Rotation 0/90/180/270"/>
                                                            <ComboBox Grid.Column="5"
                                                                      FontSize="10"
                                                                      Padding="2,1"
                                                                      VerticalAlignment="Center"
                                                                      Width="44"
                                                                      SelectedValue="{Binding GerberRotation}"
                                                                      SelectedValuePath="Content"
                                                                      ToolTip="Rotation angle (degrees)">
                                                                <ComboBoxItem Content="0"/>
                                                                <ComboBoxItem Content="90"/>
                                                                <ComboBoxItem Content="180"/>
                                                                <ComboBoxItem Content="270"/>
                                                            </ComboBox>
                                                        </Grid>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Expander>
                        </StackPanel>
                    </GroupBox>

                    <!-- RF Module Settings -->
                    <GroupBox Margin="0,0,0,10"
                              Padding="5">
                        <GroupBox.Header>
                            <CheckBox Content="RF Module (Antenna)"
                                      IsChecked="{Binding HasModule}"
                                      FontWeight="Normal"
                                      VerticalAlignment="Center"/>
                        </GroupBox.Header>
                        <StackPanel IsEnabled="{Binding HasModule}">
                            <Grid Margin="0,2,0,2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Label Content="Length:"
                                       Grid.Column="0"
                                       VerticalAlignment="Center"
                                       Padding="3,0"/>
                                <TextBox Text="{Binding Module.Width}"
                                         Grid.Column="1"
                                         Margin="2"
                                         VerticalAlignment="Center"/>
                                <Label Content="Width:"
                                       Grid.Column="2"
                                       VerticalAlignment="Center"
                                       Padding="3,0"/>
                                <TextBox Text="{Binding Module.Height}"
                                         Grid.Column="3"
                                         Margin="2"
                                         VerticalAlignment="Center"/>
                            </Grid>

                            <Grid Margin="0,2,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="70"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Label Content="Thickness:"
                                       Grid.Column="0"
                                       VerticalAlignment="Center"
                                       Padding="3,0"/>
                                <TextBox Grid.Column="1"
                                         Text="{Binding Module.Thickness, UpdateSourceTrigger=LostFocus}"
                                         Margin="2"
                                         VerticalAlignment="Center"/>
                                <TextBlock Text="mm"
                                           Grid.Column="2"
                                           VerticalAlignment="Center"
                                           Margin="2,0,8,0"/>
                                <Label Content="Layers:"
                                       Grid.Column="3"
                                       VerticalAlignment="Center"
                                       Padding="3,0"/>
                                <ComboBox Grid.Column="4"
                                          ItemsSource="{Binding AvailableLayerCounts}"
                                          SelectedItem="{Binding Module.LayerCount}"
                                          VerticalAlignment="Center"
                                          Margin="2"/>
                            </Grid>

                            <Label Content="Position offset (0,0 = flush right edge, centred):"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Label Content="X:"
                                       Grid.Column="0"/>
                                <TextBox Text="{Binding Module.PositionX}"
                                         Grid.Column="1"
                                         Margin="2"/>
                                <Label Content="Y:"
                                       Grid.Column="2"/>
                                <TextBox Text="{Binding Module.PositionY}"
                                         Grid.Column="3"
                                         Margin="2"/>
                            </Grid>

                            <Expander Header="Module Stackup"
                                      Margin="0,5,0,0"
                                      IsExpanded="True">
                                <DataGrid ItemsSource="{Binding Module.Stackup.Layers}"
                                          AutoGenerateColumns="False"
                                          MinHeight="200"
                                          MaxHeight="500"
                                          CanUserAddRows="True"
                                          HorizontalScrollBarVisibility="Hidden"
                                          VerticalScrollBarVisibility="Auto">
                                    <DataGrid.Columns>
                                        <DataGridTemplateColumn Header="Name"
                                                                Width="2*">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <StackPanel Orientation="Horizontal"
                                                                VerticalAlignment="Center">
                                                        <CheckBox IsChecked="{Binding IsVisible, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                                                  Margin="2,0,4,0"
                                                                  VerticalAlignment="Center"/>
                                                        <TextBlock Text="{Binding Name}"
                                                                   VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                            <DataGridTemplateColumn.CellEditingTemplate>
                                                <DataTemplate>
                                                    <StackPanel Orientation="Horizontal"
                                                                VerticalAlignment="Center">
                                                        <CheckBox IsChecked="{Binding IsVisible, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                                                  Margin="2,0,4,0"
                                                                  VerticalAlignment="Center"/>
                                                        <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                                                                 BorderThickness="0"
                                                                 VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellEditingTemplate>
                                        </DataGridTemplateColumn>
                                        <DataGridTextColumn Header="Thick(mm)"
                                                            Binding="{Binding Thickness}"
                                                            Width="*"/>
                                        <DataGridComboBoxColumn Header="Material"
                                                                Width="2*"
                                                                DisplayMemberPath="DisplayName"
                                                                SelectedValuePath="Value"
                                                                SelectedValueBinding="{Binding Material, UpdateSourceTrigger=PropertyChanged}"
                                                                ItemsSource="{StaticResource MaterialPresets}"/>
                                        <DataGridTextColumn Header="Dk"
                                                            Width="40"
                                                            Binding="{Binding DielectricConstant, StringFormat='{}{0:0.##}'}"/>
                                        <DataGridTemplateColumn Header="Gerber / Align"
                                                                Width="3*">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <StackPanel Margin="2,1"
                                                                Visibility="{Binding IsConductive, Converter={StaticResource BoolToVis}}">
                                                        <!-- file picker row -->
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="{Binding GerberFileName}"
                                                                       FontSize="10"
                                                                       VerticalAlignment="Center"
                                                                       MaxWidth="75"
                                                                       TextTrimming="CharacterEllipsis"
                                                                       ToolTip="{Binding GerberFilePath}"/>
                                                            <Button Content="…"
                                                                    Tag="{Binding}"
                                                                    Click="GerberBrowse_Click"
                                                                    Padding="3,1"
                                                                    Margin="2,0"
                                                                    ToolTip="Assign Gerber file"/>
                                                            <Button Content="×"
                                                                    Tag="{Binding}"
                                                                    Click="GerberClear_Click"
                                                                    Padding="3,1"
                                                                    Visibility="{Binding HasGerber, Converter={StaticResource BoolToVis}}"
                                                                    ToolTip="Remove Gerber file"/>
                                                        </StackPanel>
                                                        <!-- X/Y offset + rotation (shown only when file is assigned) -->
                                                        <Grid Visibility="{Binding HasGerber, Converter={StaticResource BoolToVis}}"
                                                              Margin="0,2,0,1">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="44"/>
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Text="X:"
                                                                       Grid.Column="0"
                                                                       FontSize="10"
                                                                       VerticalAlignment="Center"
                                                                       ToolTip="Gerber X offset (mm)"/>
                                                            <TextBox Grid.Column="1"
                                                                     FontSize="10"
                                                                     Padding="1"
                                                                     Text="{Binding GerberOffsetX, UpdateSourceTrigger=LostFocus, StringFormat='{}{0:0.###}'}"
                                                                     ToolTip="X offset in mm"/>
                                                            <TextBlock Text="Y:"
                                                                       Grid.Column="2"
                                                                       FontSize="10"
                                                                       VerticalAlignment="Center"
                                                                       Margin="3,0,0,0"
                                                                       ToolTip="Gerber Y offset (mm)"/>
                                                            <TextBox Grid.Column="3"
                                                                     FontSize="10"
                                                                     Padding="1"
                                                                     Text="{Binding GerberOffsetY, UpdateSourceTrigger=LostFocus, StringFormat='{}{0:0.###}'}"
                                                                     ToolTip="Y offset in mm"/>
                                                            <TextBlock Text="°:"
                                                                       Grid.Column="4"
                                                                       FontSize="10"
                                                                       VerticalAlignment="Center"
                                                                       Margin="3,0,0,0"
                                                                       ToolTip="Rotation 0/90/180/270"/>
                                                            <ComboBox Grid.Column="5"
                                                                      FontSize="10"
                                                                      Padding="2,1"
                                                                      VerticalAlignment="Center"
                                                                      Width="44"
                                                                      SelectedValue="{Binding GerberRotation}"
                                                                      SelectedValuePath="Content"
                                                                      ToolTip="Rotation angle (degrees)">
                                                                <ComboBoxItem Content="0"/>
                                                                <ComboBoxItem Content="90"/>
                                                                <ComboBoxItem Content="180"/>
                                                                <ComboBoxItem Content="270"/>
                                                            </ComboBox>
                                                        </Grid>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Expander>
                        </StackPanel>
                    </GroupBox>

                    <!-- Drawn Objects Summary -->
                    <GroupBox Header="Drawn Objects"
                              Margin="0,0,0,10"
                              Padding="5">
                        <StackPanel>

                            <!-- ── Copper Shapes ──────────────────────── -->
                            <Expander Header="Copper Shapes"
                                      IsExpanded="True"
                                      Margin="0,0,0,4">
                                <DataGrid x:Name="CopperShapesGrid"
                                          AutoGenerateColumns="False"
                                          CanUserAddRows="False"
                                          CanUserDeleteRows="False"
                                          IsReadOnly="False"
                                          HeadersVisibility="Column"
                                          MinHeight="28"
                                          MaxHeight="200"
                                          HorizontalScrollBarVisibility="Hidden"
                                          VerticalScrollBarVisibility="Auto"
                                          GridLinesVisibility="Horizontal"
                                          BorderThickness="1"
                                          FontSize="11">
                                    <DataGrid.Columns>
                                        <DataGridTemplateColumn Header="Name"
                                                                Width="3*">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <StackPanel Orientation="Horizontal"
                                                                VerticalAlignment="Center">
                                                        <CheckBox IsChecked="{Binding ShowIn3D, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                                                  Margin="2,0,4,0"
                                                                  VerticalAlignment="Center"
                                                                  Checked="DrawnObjectVisibility_Changed"
                                                                  Unchecked="DrawnObjectVisibility_Changed"/>
                                                        <TextBlock Text="{Binding Name}"
                                                                   VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                        <DataGridTextColumn Header="Layer"
                                                            Width="2*"
                                                            Binding="{Binding LayerName}"
                                                            IsReadOnly="True"/>
                                        <DataGridTextColumn Header="Board"
                                                            Width="*"
                                                            Binding="{Binding BoardLabel}"
                                                            IsReadOnly="True"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Expander>

                            <!-- ── Antennas ───────────────────────────── -->
                            <Expander Header="Antennas"
                                      IsExpanded="True"
                                      Margin="0,0,0,4">
                                <DataGrid x:Name="AntennasGrid"
                                          AutoGenerateColumns="False"
                                          CanUserAddRows="False"
                                          CanUserDeleteRows="False"
                                          IsReadOnly="False"
                                          HeadersVisibility="Column"
                                          MinHeight="28"
                                          MaxHeight="200"
                                          HorizontalScrollBarVisibility="Hidden"
                                          VerticalScrollBarVisibility="Auto"
                                          GridLinesVisibility="Horizontal"
                                          BorderThickness="1"
                                          FontSize="11">
                                    <DataGrid.Columns>
                                        <DataGridTemplateColumn Header="Name"
                                                                Width="3*">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <StackPanel Orientation="Horizontal"
                                                                VerticalAlignment="Center">
                                                        <CheckBox IsChecked="{Binding ShowIn3D, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                                                  Margin="2,0,4,0"
                                                                  VerticalAlignment="Center"
                                                                  Checked="DrawnObjectVisibility_Changed"
                                                                  Unchecked="DrawnObjectVisibility_Changed"/>
                                                        <TextBlock Text="{Binding Name}"
                                                                   VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                        <DataGridTextColumn Header="Layer"
                                                            Width="2*"
                                                            Binding="{Binding LayerName}"
                                                            IsReadOnly="True"/>
                                        <DataGridTextColumn Header="Board"
                                                            Width="*"
                                                            Binding="{Binding BoardLabel}"
                                                            IsReadOnly="True"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Expander>

                            <!-- ── Vias ───────────────────────────────── -->
                            <Expander Header="Vias"
                                      IsExpanded="True"
                                      Margin="0,0,0,0">
                                <DataGrid ItemsSource="{Binding Vias}"
                                          AutoGenerateColumns="False"
                                          CanUserAddRows="False"
                                          CanUserDeleteRows="False"
                                          IsReadOnly="False"
                                          HeadersVisibility="Column"
                                          MinHeight="28"
                                          MaxHeight="200"
                                          HorizontalScrollBarVisibility="Hidden"
                                          VerticalScrollBarVisibility="Auto"
                                          GridLinesVisibility="Horizontal"
                                          BorderThickness="1"
                                          FontSize="11">
                                    <DataGrid.Columns>
                                        <DataGridTemplateColumn Header="Name"
                                                                Width="2*">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <StackPanel Orientation="Horizontal"
                                                                VerticalAlignment="Center">
                                                        <CheckBox IsChecked="{Binding ShowIn3D, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                                                  Margin="2,0,4,0"
                                                                  VerticalAlignment="Center"
                                                                  Checked="DrawnObjectVisibility_Changed"
                                                                  Unchecked="DrawnObjectVisibility_Changed"/>
                                                        <TextBlock Text="{Binding Name}"
                                                                   VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                        <DataGridTextColumn Header="From"
                                                            Width="*"
                                                            Binding="{Binding FromLayer}"
                                                            IsReadOnly="True"/>
                                        <DataGridTextColumn Header="To"
                                                            Width="*"
                                                            Binding="{Binding ToLayer}"
                                                            IsReadOnly="True"/>
                                        <DataGridTextColumn Header="⌀ mil"
                                                            Width="*"
                                                            Binding="{Binding DiameterMil}"
                                                            IsReadOnly="True"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Expander>

                            <!-- ── Solder Joints ──────────────────────── -->
                            <Expander Header="Solder Joints"
                                      IsExpanded="True"
                                      Margin="0,0,0,0">
                                <DataGrid ItemsSource="{Binding SolderJoints}"
                                          AutoGenerateColumns="False"
                                          CanUserAddRows="False"
                                          CanUserDeleteRows="False"
                                          IsReadOnly="False"
                                          HeadersVisibility="Column"
                                          MinHeight="28"
                                          MaxHeight="200"
                                          HorizontalScrollBarVisibility="Hidden"
                                          VerticalScrollBarVisibility="Auto"
                                          GridLinesVisibility="Horizontal"
                                          BorderThickness="1"
                                          FontSize="11">
                                    <DataGrid.Columns>
                                        <DataGridTemplateColumn Header="Name"
                                                                Width="2*">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <StackPanel Orientation="Horizontal"
                                                                VerticalAlignment="Center">
                                                        <CheckBox IsChecked="{Binding ShowIn3D, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                                                  Margin="2,0,4,0"
                                                                  VerticalAlignment="Center"
                                                                  Checked="DrawnObjectVisibility_Changed"
                                                                  Unchecked="DrawnObjectVisibility_Changed"/>
                                                        <TextBlock Text="{Binding Name}"
                                                                   VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                        <DataGridTextColumn Header="X"
                                                            Width="*"
                                                            Binding="{Binding X, StringFormat=F2}"
                                                            IsReadOnly="True"/>
                                        <DataGridTextColumn Header="Y"
                                                            Width="*"
                                                            Binding="{Binding Y, StringFormat=F2}"
                                                            IsReadOnly="True"/>
                                        <DataGridTextColumn Header="⌀ mil"
                                                            Width="*"
                                                            Binding="{Binding DiameterMil}"
                                                            IsReadOnly="True"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Expander>

                        </StackPanel>
                    </GroupBox>

                    <Button Content="Simulate"
                            Height="40"
                            Margin="0,10"
                            Background="#DDDDDD"
                            Click="MenuSimulate_Click"/>

                </StackPanel>
            </ScrollViewer>

            <!-- 3D Visualization Placeholder -->
            <Border Grid.Column="1"
                    Background="#C8D0D8"
                    Margin="5"
                    CornerRadius="3">
                <Grid>

                    <!-- View control toolbar -->
                    <Border VerticalAlignment="Top"
                            HorizontalAlignment="Left"
                            Background="#DD2B3A4A"
                            CornerRadius="4"
                            Margin="8"
                            Padding="4"
                            Panel.ZIndex="10">
                        <Border.Resources>
                            <Style TargetType="Button">
                                <Setter Property="Foreground"
                                        Value="#EEEEEE"/>
                                <Setter Property="Background"
                                        Value="#444444"/>
                                <Setter Property="BorderBrush"
                                        Value="#666666"/>
                                <Setter Property="BorderThickness"
                                        Value="1"/>
                                <Setter Property="Margin"
                                        Value="2,2"/>
                                <Setter Property="Padding"
                                        Value="7,3"/>
                                <Setter Property="FontSize"
                                        Value="11"/>
                                <Setter Property="Cursor"
                                        Value="Hand"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                    CornerRadius="3"
                                                    Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center"
                                                                  VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver"
                                                         Value="True">
                                                    <Setter Property="Background"
                                                            Value="#606060"/>
                                                </Trigger>
                                                <Trigger Property="IsPressed"
                                                         Value="True">
                                                    <Setter Property="Background"
                                                            Value="#2288CC"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Border.Resources>
                        <StackPanel Orientation="Vertical">
                            <!-- View preset row -->
                            <StackPanel Orientation="Horizontal">
                                <Button Content="Top"
                                        ToolTip="Top view (–Z)"
                                        Click="ViewTop_Click"/>
                                <Button Content="Bottom"
                                        ToolTip="Bottom view (+Z)"
                                        Click="ViewBottom_Click"/>
                                <Button Content="Front"
                                        ToolTip="Front view (–Y)"
                                        Click="ViewFront_Click"/>
                                <Button Content="Back"
                                        ToolTip="Back view (+Y)"
                                        Click="ViewBack_Click"/>
                                <Button Content="Left"
                                        ToolTip="Left view (–X)"
                                        Click="ViewLeft_Click"/>
                                <Button Content="Right"
                                        ToolTip="Right view (+X)"
                                        Click="ViewRight_Click"/>
                            </StackPanel>
                            <!-- Zoom row -->
                            <StackPanel Orientation="Horizontal"
                                        HorizontalAlignment="Center">
                                <Button Content="＋ Zoom In"
                                        ToolTip="Zoom in"
                                        Click="ZoomIn_Click"/>
                                <Button Content="－ Zoom Out"
                                        ToolTip="Zoom out"
                                        Click="ZoomOut_Click"/>
                                <Button Content="⛶ Fit"
                                        ToolTip="Zoom fit"
                                        Click="ZoomFit_Click"/>
                                <Button x:Name="ZScaleButton"
                                        Content="Z ×10"
                                        ToolTip="Toggle Z-axis 10x exaggeration"
                                        Click="ZScaleToggle_Click"/>
                                <Button Content="↺ Refresh"
                                        ToolTip="Rebuild 3D layer visuals"
                                        Click="Refresh3D_Click"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <h:HelixViewport3D x:Name="Viewport3D"
                                       Background="#C8D0D8"
                                       ShowCoordinateSystem="True"
                                       ShowViewCube="False"
                                       CameraRotationMode="Trackball"
                                       IsRotationEnabled="False"
                                       IsPanEnabled="False"
                                       IsZoomEnabled="False"
                                       MouseWheel="Viewport3D_MouseWheel"
                                       Loaded="Viewport3D_Loaded">
                        <h:DefaultLights/>
                        <h:GridLinesVisual3D Width="200"
                                             Length="200"
                                             MinorDistance="5"
                                             MajorDistance="20"
                                             Thickness="0.1"
                                             Fill="#6688A0"/>

                        <!-- Origin marker: red sphere at (0,0,0) – outside SceneRoot so Z-scale does not distort it -->
                        <h:SphereVisual3D Center="0,0,0"
                                          Radius="1.2"
                                          PhiDiv="12"
                                          ThetaDiv="16"
                                          Fill="Red"/>

                        <!-- Carrier Board – one BoxVisual3D per stackup layer -->
                        <!-- RF Module – one BoxVisual3D per stackup layer -->
                        <!-- Both wrapped in SceneRoot so Z-scale can be toggled -->
                        <ModelVisual3D x:Name="SceneRoot">
                            <ModelVisual3D.Transform>
                                <Transform3DGroup>
                                    <ScaleTransform3D x:Name="ZScaleTransform"
                                                      ScaleX="1"
                                                      ScaleY="1"
                                                      ScaleZ="10"/>
                                </Transform3DGroup>
                            </ModelVisual3D.Transform>
                            <ModelVisual3D x:Name="CarrierVisual3D"/>
                            <ModelVisual3D x:Name="ModuleVisual3D"/>
                            <!-- Drawn objects: rendered in ascending priority order -->
                            <ModelVisual3D x:Name="CopperShapeVisual3D"/>
                            <ModelVisual3D x:Name="AntennaVisual3D"/>
                            <ModelVisual3D x:Name="ViaVisual3D"/>
                            <ModelVisual3D x:Name="SolderJointVisual3D"/>
                            <ModelVisual3D x:Name="PortVisual3D"/>
                            <!-- Transparent substrate/dielectric layers rendered LAST -->
                            <!-- so they never occlude opaque copper geometry above -->
                            <ModelVisual3D x:Name="TransparentVisual3D"/>
                        </ModelVisual3D>
                    </h:HelixViewport3D>

                </Grid>
            </Border>

        </Grid>
    </DockPanel>
</Window>
