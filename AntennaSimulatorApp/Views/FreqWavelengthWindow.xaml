<Window x:Class="AntennaSimulatorApp.Views.FreqWavelengthWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Frequency / Wavelength Converter"
        Width="520"
        Height="460"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip"
        Background="#F5F5F5">

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Description -->
        <TextBlock Grid.Row="0"
                   TextWrapping="Wrap"
                   Margin="0,0,0,10"
                   Foreground="#555"
                   Text="Convert between frequency and wavelength.  λ = c / (f · √εᵣ).  Enter a value in any field and press Enter or click Calculate."/>

        <!-- Input group -->
        <GroupBox Grid.Row="1"
                Header="Input"
                Margin="0,0,0,8">
            <Grid Margin="6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="130"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="90"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="30"/>
                </Grid.RowDefinitions>

                <Label Content="Frequency:"
                        VerticalAlignment="Center"/>
                <TextBox x:Name="FreqBox"
                        Grid.Column="1"
                         VerticalContentAlignment="Center"
                         Margin="0,2"
                        Padding="4,2"
                         KeyDown="InputBox_KeyDown"/>
                <ComboBox x:Name="FreqUnitCombo"
                        Grid.Column="2"
                          Margin="4,2"
                        VerticalContentAlignment="Center"
                          SelectionChanged="Unit_Changed">
                    <ComboBoxItem Content="Hz"/>
                    <ComboBoxItem Content="kHz"/>
                    <ComboBoxItem Content="MHz"/>
                    <ComboBoxItem Content="GHz"
                            IsSelected="True"/>
                </ComboBox>

                <Label Content="Relative permittivity εᵣ:"
                        Grid.Row="1"
                        VerticalAlignment="Center"/>
                <TextBox x:Name="ErBox"
                        Grid.Row="1"
                        Grid.Column="1"
                         Text="1.0"
                         VerticalContentAlignment="Center"
                         Margin="0,2"
                        Padding="4,2"
                         KeyDown="InputBox_KeyDown"/>
                <Button Content="Calculate"
                        Grid.Row="1"
                        Grid.Column="2"
                        Margin="4,2"
                        Padding="4,2"
                        Click="Calculate_Click"/>
            </Grid>
        </GroupBox>

        <!-- Results group -->
        <GroupBox Grid.Row="2"
                Header="Results"
                Margin="0,0,0,8">
            <Grid Margin="6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="180"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="26"/>
                    <RowDefinition Height="26"/>
                    <RowDefinition Height="26"/>
                    <RowDefinition Height="26"/>
                    <RowDefinition Height="26"/>
                    <RowDefinition Height="26"/>
                </Grid.RowDefinitions>

                <Label Content="Frequency:"
                        VerticalAlignment="Center"/>
                <TextBlock x:Name="ResultFreq"
                        Grid.Column="1"
                        VerticalAlignment="Center"
                        FontWeight="SemiBold"/>

                <Label Content="Free-space wavelength λ₀:"
                        Grid.Row="1"
                        VerticalAlignment="Center"/>
                <TextBlock x:Name="ResultLambda0"
                        Grid.Row="1"
                        Grid.Column="1"
                        VerticalAlignment="Center"
                        FontWeight="SemiBold"/>

                <Label Content="In-medium wavelength λ:"
                        Grid.Row="2"
                        VerticalAlignment="Center"/>
                <TextBlock x:Name="ResultLambdaM"
                        Grid.Row="2"
                        Grid.Column="1"
                        VerticalAlignment="Center"
                        FontWeight="SemiBold"/>

                <Label Content="λ/4 (quarter-wave):"
                        Grid.Row="3"
                        VerticalAlignment="Center"/>
                <TextBlock x:Name="ResultQuarter"
                        Grid.Row="3"
                        Grid.Column="1"
                        VerticalAlignment="Center"/>

                <Label Content="λ/2 (half-wave):"
                        Grid.Row="4"
                        VerticalAlignment="Center"/>
                <TextBlock x:Name="ResultHalf"
                        Grid.Row="4"
                        Grid.Column="1"
                        VerticalAlignment="Center"/>

                <Label Content="Wave number k (rad/m):"
                        Grid.Row="5"
                        VerticalAlignment="Center"/>
                <TextBlock x:Name="ResultK"
                        Grid.Row="5"
                        Grid.Column="1"
                        VerticalAlignment="Center"/>
            </Grid>
        </GroupBox>

        <!-- Common εr presets -->
        <GroupBox Grid.Row="3"
                Header="Common εᵣ Presets">
            <WrapPanel Margin="4">
                <Button Content="Vacuum (1.0)"
                        Tag="1.0"
                        Click="Preset_Click"
                        Margin="2"
                        Padding="6,2"/>
                <Button Content="PTFE (2.1)"
                        Tag="2.1"
                        Click="Preset_Click"
                        Margin="2"
                        Padding="6,2"/>
                <Button Content="Rogers 4350B (3.48)"
                        Tag="3.48"
                        Click="Preset_Click"
                        Margin="2"
                        Padding="6,2"/>
                <Button Content="FR-4 (4.4)"
                        Tag="4.4"
                        Click="Preset_Click"
                        Margin="2"
                        Padding="6,2"/>
                <Button Content="Alumina (9.8)"
                        Tag="9.8"
                        Click="Preset_Click"
                        Margin="2"
                        Padding="6,2"/>
                <Button Content="Silicon (11.9)"
                        Tag="11.9"
                        Click="Preset_Click"
                        Margin="2"
                        Padding="6,2"/>
            </WrapPanel>
        </GroupBox>
    </Grid>
</Window>
